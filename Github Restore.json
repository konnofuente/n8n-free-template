        {
            "parameters": {
                "jsCode": "// Build a clean Telegram summary message\nconst items = $input.all();\nconst created = items.filter(i => i.json.isNew);\nconst updated = items.filter(i => !i.json.isNew);\n\nconst lines = [\n  '🔄 *n8n Sync Complete*',\n  ''\n];\n\nif (created.length > 0) {\n  lines.push('🆕 *New workflows created:*');\n  for (const item of created) {\n    lines.push(`  • ${item.json.workflowName} (ID: ${item.json.workflowId})`);\n  }\n  lines.push('');\n}\n\nif (updated.length > 0) {\n  lines.push('✅ *Workflows updated:*');\n  for (const item of updated) {\n    lines.push(`  • ${item.json.workflowName}`);\n  }\n  lines.push('');\n}\n\nconst now = new Date().toLocaleString('en-GB', {\n  timeZone: 'Africa/Douala',\n  day: '2-digit', month: '2-digit', year: 'numeric',\n  hour: '2-digit', minute: '2-digit'\n});\n\nlines.push(`🕐 *Time:* ${now}`);\nlines.push('');\nlines.push('🔗 Source: github.com/konnofuente/n8n-free-template');\n\nreturn [{ json: { message: lines.join('\\n') } }];"
            },
