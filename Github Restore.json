        {
            "parameters": {
                "url": "=https://api.github.com/repos/{{ $json.repoFullName }}/contents/{{ encodeURIComponent($json.filePath) }}?ref={{ $json.ref }}",
                "authentication": "genericCredentialType",
                "genericAuthType": "httpHeaderAuth",
                "options": {
                    "response": {
                        "response": {
                            "responseFormat": "json"
                        }
                    }
                }
            },
            "id": "a1000005-0000-0000-0000-000000000005",
            "name": "Get file from GitHub",
            "type": "n8n-nodes-base.httpRequest",
            "position": [
                860,
                220
            ],
            "typeVersion": 4.3,
            "continueOnFail": true,
            "credentials": {
                "httpHeaderAuth": {
                    "id": "z8h44D4OqbDOXai8",
                    "name": "GitHub account"
                }
            }
        },
        {
            "parameters": {
                "jsCode": "// Decode base64 content from GitHub and extract workflow data\nconst item = $input.item.json;\n\n// GitHub returns content with newlines in the base64 — strip them\nconst raw = (item.content || '').replace(/\\n/g, '');\nif (!raw) {\n  return [{ json: { skipped: true, reason: 'No content', file: item.name } }];\n}\n\nlet workflow;\ntry {\n  const decoded = Buffer.from(raw, 'base64').toString('utf8');\n  workflow = JSON.parse(decoded);\n} catch (e) {\n  return [{ json: { skipped: true, reason: 'Invalid JSON', file: item.name } }];\n}\n\n// Check if this looks like an n8n workflow (must have name and nodes)\nif (!workflow.name || !workflow.nodes) {\n  return [{ json: { skipped: true, reason: 'Not an n8n workflow (missing name or nodes)', file: item.name } }];\n}\n\n// Determine if this is a new workflow (no id) or existing (has id)\nconst isNew = !workflow.id;\n\nreturn [{\n  json: {\n    skipped: false,\n    isNew: isNew,\n    workflowId: workflow.id || null,\n    workflowName: workflow.name,\n    workflowData: workflow,\n    filePath: item.path\n  }\n}];"
            },
            "id": "a1000006-0000-0000-0000-000000000006",
            "name": "Decode & extract workflow",
            "type": "n8n-nodes-base.code",
