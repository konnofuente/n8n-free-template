        {
            "parameters": {
                "jsCode": "// Check if the API call succeeded or failed\n// Works for both Create and Update responses\nconst item = $input.item.json;\nconst decodeData = $('Decode & extract workflow').item.json;\n\nconst hasError = item.error || item.message === 'Not Found' || (item.code && item.code >= 400);\n\nif (hasError) {\n  return [{\n    json: {\n      success: false,\n      workflowName: decodeData.workflowName,\n      filePath: decodeData.filePath,\n      isNew: decodeData.isNew,\n      error: item.error?.message || item.message || JSON.stringify(item).substring(0, 300)\n    }\n  }];\n}\n\n// Success — extract the new ID if this was a create\nconst newId = item.id || decodeData.workflowId;\n\nreturn [{\n  json: {\n    success: true,\n    workflowName: item.name || decodeData.workflowName,\n    workflowId: newId,\n    filePath: decodeData.filePath,\n    isNew: decodeData.isNew,\n    action: decodeData.isNew ? 'CREATED' : 'UPDATED'\n  }\n}];"
            },
