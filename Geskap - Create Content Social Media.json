      "parameters": {
        "jsCode": "// Extract image URL and combine with content data\nconst imageData = $('Get Image Result').first().json;\nconst contentData = $('Parse AI Response').first().json;\n\nconst imageUrl = imageData.data?.output?.image_url \n  || imageData.data?.output?.images?.[0] \n  || imageData.output?.image_url \n  || imageData.output?.images?.[0] \n  || '';\n\nreturn [{\n  json: {\n    ...contentData,\n    image_url: imageUrl,\n    execution_id: $execution.id\n  }\n}];"
