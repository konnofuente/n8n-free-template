    {
      "parameters": {
        "jsCode": "// Parse the AI response into structured content\nconst output = $input.first().json.output || $input.first().json.text || '';\n\nlet content;\ntry {\n  // Try to parse JSON directly\n  const jsonMatch = output.match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) {\n    content = JSON.parse(jsonMatch[0]);\n  } else {\n    throw new Error('No JSON found in AI response');\n  }\n} catch (e) {\n  // Fallback: use the raw output as a generic caption\n  content = {\n    tiktok: { caption: output.substring(0, 500) },\n    instagram: { caption: output.substring(0, 800) },\n    facebook: { caption: output },\n    image_prompt: 'Modern flat design social media visual with dark green #194E2F background, African business context, clean and professional'\n  };\n}\n\nreturn [{\n  json: {\n    tiktok_caption: content.tiktok?.caption || '',\n    instagram_caption: content.instagram?.caption || '',\n    facebook_caption: content.facebook?.caption || '',\n    image_prompt: content.image_prompt || 'Modern flat design social media visual with dark green #194E2F background, African business context, clean and professional',\n    pillar: $('Select Content Pillar').first().json.pillar\n  }\n}];"
      },
